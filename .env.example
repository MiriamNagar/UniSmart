# Public Firebase Web config only (safe for the client). Copy to `.env` and fill in.
# Never add service account JSON or Admin SDK keys here.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Google Sign-In (OAuth 2.0 Web client ID from Firebase Console → Project settings; used by native + config plugin)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# iOS only: reversed client ID for URL scheme (Google Cloud Console → iOS OAuth client), e.g. com.googleusercontent.apps.123...
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=

# --- Server / seed scripts only (never commit the JSON path into the repo) ---
# Firebase Admin SDK — download from Firebase Console → Project settings → Service accounts.
# Windows PowerShell: $env:GOOGLE_APPLICATION_CREDENTIALS="C:\path\to\serviceAccount.json"
# Then: node scripts/seed-firestore-3nf.mjs
# GOOGLE_APPLICATION_CREDENTIALS=
